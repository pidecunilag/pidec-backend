# ─────────────────────────────────────────────────────────────
# PIDEC 1.0 — Environment Variables
# Copy to .env.local (web) and .env (api). Never commit real values.
# ─────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
# From Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# BACKEND ONLY — NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection (optional — we don't use it since migrations are manual)
DATABASE_URL=

# ── App URLs ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_PLATFORM_EMAIL=competitions@pidec.com.ng
APP_URL=http://localhost:3000

# ── API Server ────────────────────────────────────────────────
API_PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
COOKIE_DOMAIN=localhost
LOG_LEVEL=info

# ── Redis / Queue ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Email (Resend) ────────────────────────────────────────────
# Set once domain competitions@pidec.com.ng is verified in Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL="PIDEC 1.0 <competitions@pidec.com.ng>"

# ── AI Verification ───────────────────────────────────────────
GROQ_API_KEY=
GEMINI_API_KEY=

# ── Rate Limiting (defaults shown) ────────────────────────────
RATE_LIMIT_REGISTRATION_WINDOW_MS=600000
RATE_LIMIT_REGISTRATION_MAX=5
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_GLOBAL_WINDOW_MS=60000
RATE_LIMIT_GLOBAL_ANON_MAX=100
RATE_LIMIT_GLOBAL_AUTH_MAX=500
