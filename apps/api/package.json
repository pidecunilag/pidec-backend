    "@react-email/render": "^1.0.1",
    "@supabase/supabase-js": "^2.45.6",
    "@types/multer": "^2.1.0",
    "bullmq": "^5.21.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "groq-sdk": "^1.1.2",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "multer": "^2.1.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^11.3.0",
